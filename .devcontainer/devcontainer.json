{
	"name": "pygeoapi-dev",
	"dockerComposeFile": "docker-compose.yml",
	"service": "pygeoapi",
	"workspaceFolder": "/workspaces/wxs-pygeoapi",
	"shutdownAction": "stopCompose",
	"runServices": [
		"postgres"
	],
"features": {
	"ghcr.io/devcontainers/features/common-utils:2": {
		"installZsh": "true",
		"configureZshAsDefaultShell": "true"
	}
}
}
